// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  fullName       String
  cpf            String    @unique
  phone          String?
  role           Role      @default(CUSTOMER)
  emailConfirmed Boolean   @default(false)
  blocked        Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  addresses      Address[]
  wallet         Wallet?
  orders         Order[]
  warehouseItems WarehouseItem[]
  shipments      Shipment[]
  tickets        Ticket[]
  auditLogs      AuditLog[]

  @@map("users")
}

model Address {
  id           String   @id @default(uuid())
  userId       String
  label        String   @default("Principal")
  cep          String
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String   @db.Char(2)
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  shipments Shipment[]

  @@index([userId])
  @@map("addresses")
}

enum Role {
  CUSTOMER
  ADMIN
}

model Wallet {
  id           String        @id @default(uuid())
  userId       String        @unique
  balance      Decimal       @default(0) @db.Decimal(10, 2)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model Order {
  id           String      @id @default(uuid())
  userId       String
  productUrl   String
  productName  String
  productImage String?
  priceJpy     Decimal     @db.Decimal(10, 2)
  priceBrl     Decimal     @db.Decimal(10, 2)
  serviceFee   Decimal     @db.Decimal(10, 2)
  fixedFee     Decimal     @db.Decimal(10, 2)
  totalBrl     Decimal     @db.Decimal(10, 2)
  quantity     Int         @default(1)
  variation    String?
  notes        String?
  status            OrderStatus @default(AWAITING_PURCHASE)
  realPriceJpy      Decimal?    @db.Decimal(10, 2)
  arrivalExpectedAt DateTime?
  receiptUrl        String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  warehouseItem WarehouseItem?

  @@index([userId])
  @@index([status])
  @@map("orders")
}

enum OrderStatus {
  PENDING_PAYMENT
  AWAITING_PURCHASE
  PURCHASED
  IN_TRANSIT_TO_WAREHOUSE
  IN_WAREHOUSE
  CANCELLED
}

model WarehouseItem {
  id                   String              @id @default(uuid())
  orderId              String?             @unique
  userId               String
  name                 String
  photos               Json                @default("[]")
  weightGrams          Int                 @default(0)
  lengthCm             Int                 @default(0)
  widthCm             Int                 @default(0)
  heightCm             Int                 @default(0)
  arrivedAt            DateTime            @default(now())
  freeStorageDeadline  DateTime?
  status               WarehouseItemStatus @default(AVAILABLE)
  lastStorageFeeAt     DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  order         Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  extraServices ExtraService[]
  shipmentItems ShipmentItem[]

  @@index([userId])
  @@index([status])
  @@index([freeStorageDeadline])
  @@map("warehouse_items")
}

enum WarehouseItemStatus {
  AVAILABLE
  SELECTED_FOR_SHIPMENT
  SHIPPED
}

model ExtraService {
  id              String             @id @default(uuid())
  warehouseItemId String
  type            ExtraServiceType
  status          ExtraServiceStatus @default(REQUESTED)
  price           Decimal            @db.Decimal(10, 2)
  resultNotes     String?
  resultPhotos    Json               @default("[]")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  warehouseItem WarehouseItem @relation(fields: [warehouseItemId], references: [id], onDelete: Cascade)

  @@map("extra_services")
}

enum ExtraServiceType {
  EXTRA_PHOTO
  QUALITY_CHECK
  REMOVE_PACKAGING
  EXTRA_PROTECTION
}

enum ExtraServiceStatus {
  REQUESTED
  COMPLETED
}

model Shipment {
  id                    String             @id @default(uuid())
  userId                String
  shippingMethod        ShippingMethod
  totalWeightGrams      Int                @default(0)
  shippingCostBrl       Decimal            @db.Decimal(10, 2)
  insuranceCostBrl      Decimal            @db.Decimal(10, 2)
  hasInsurance          Boolean            @default(false)
  declaredValueType     DeclaredValueType  @default(REAL)
  declaredValueBrl      Decimal            @db.Decimal(10, 2)
  manualDeclaredValueBrl Decimal?           @db.Decimal(10, 2)
  disclaimerAcceptedAt  DateTime?
  disclaimerIp          String?
  disclaimerTextVersion String?
  addressId             String
  trackingCode          String?
  status                ShipmentStatus     @default(PREPARING)
  realShippingCostBrl   Decimal?           @db.Decimal(10, 2)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  address       Address        @relation(fields: [addressId], references: [id])
  shipmentItems ShipmentItem[]

  @@index([userId])
  @@index([status])
  @@map("shipments")
}

model OperationalCost {
  id          String   @id @default(uuid())
  description String
  amount      Decimal  @db.Decimal(10, 2)
  date        DateTime @db.Date
  category    String   @default("OTHER") // Ex: ALUGUEL, MARKETING, SOFTWARES
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("operational_costs")
}

model SystemConfig {
  id                String   @id @default("CURRENT")
  serviceFeePercent Decimal  @db.Decimal(5, 2) @default(10.00)
  fixedFeeBrl       Decimal  @db.Decimal(10, 2) @default(30.00)
  freeStorageDays   Int      @default(60)
  storageFeePerDay  Decimal  @db.Decimal(10, 2) @default(5.00)
  jpyExchangeRate   Decimal  @db.Decimal(10, 4) @default(0.0350)
  
  // Novos campos para Task 5.6
  shippingRates      Json     @default("{}") // Estrutura da Task 3.7
  extraServicePrices Json     @default("{}") // { EXTRA_PHOTO: 10, ... }
  allowedPlatforms   Json     @default("[]") // ["amazon.co.jp", ...]
  prohibitedProducts Json     @default("[]") // ["Baterias", "Líquidos", ...]
  
  updatedAt         DateTime @updatedAt

  @@map("system_configs")
}

model LegalDocument {
  id        String   @id @default(uuid())
  type      String   @default("TERMS_OF_RESPONSIBILITY")
  content   String   @db.Text
  version   Int      @default(1)
  createdAt DateTime @default(now())

  @@map("legal_documents")
}

enum ShippingMethod {
  SAL
  EMS
  DHL
  FEDEX
}

enum ShipmentStatus {
  PREPARING
  SHIPPED
  IN_TRANSIT
  IN_BRAZIL
  OUT_FOR_DELIVERY
  DELIVERED
}

enum DeclaredValueType {
  REAL
  MANUAL
}

model ShipmentItem {
  id              String @id @default(uuid())
  shipmentId      String
  warehouseItemId String

  shipment      Shipment      @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  warehouseItem WarehouseItem @relation(fields: [warehouseItemId], references: [id], onDelete: Cascade)

  @@unique([shipmentId, warehouseItemId])
  @@map("shipment_items")
}

model Transaction {
  id          String          @id @default(uuid())
  walletId    String
  type        TransactionType
  amount      Decimal         @db.Decimal(10, 2)
  description String
  referenceId String?
  createdAt   DateTime        @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@map("transactions")
}

enum TransactionType {
  CREDIT
  ORDER_PAYMENT
  SHIPPING_PAYMENT
  EXTRA_SERVICE
  STORAGE_FEE
  MANUAL_CREDIT
  MANUAL_DEBIT
  REFUND
}

model ExchangeRate {
  id        String   @id @default(uuid())
  date      DateTime @unique @db.Date
  jpyToBrl  Decimal  @db.Decimal(10, 4)
  fetchedAt DateTime @default(now())

  @@map("exchange_rates")
}

model Ticket {
  id          String         @id @default(uuid())
  userId      String
  orderId     String?
  shipmentId  String?
  type        TicketType
  subject     String
  status      TicketStatus   @default(OPEN)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    TicketMessage[]

  @@index([userId])
  @@index([status])
  @@map("tickets")
}

model TicketMessage {
  id         String   @id @default(uuid())
  ticketId   String
  authorId   String
  authorRole Role
  content    String   @db.Text
  attachments Json    @default("[]")
  createdAt  DateTime @default(now())

  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_messages")
}

enum TicketType {
  ITEM_ISSUE
  TRACKING
  BILLING
  OTHER
}

enum TicketStatus {
  OPEN
  IN_REVIEW
  RESOLVED
}

model AuditLog {
  id          String   @id @default(uuid())
  adminUserId String
  action      String
  entityType  String
  entityId    String
  details     Json     @default("{}")
  ipAddress   String?
  createdAt   DateTime @default(now())

  admin User @relation(fields: [adminUserId], references: [id])

  @@index([entityType, entityId])
  @@map("audit_logs")
}

