// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  fullName       String
  cpf            String    @unique
  phone          String?
  role           Role      @default(CUSTOMER)
  emailConfirmed Boolean   @default(false)
  blocked        Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  addresses      Address[]
  wallet         Wallet?
  orders         Order[]

  @@map("users")
}

model Address {
  id           String   @id @default(uuid())
  userId       String
  label        String   @default("Principal")
  cep          String
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String   @db.Char(2)
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

enum Role {
  CUSTOMER
  ADMIN
}

model Wallet {
  id           String        @id @default(uuid())
  userId       String        @unique
  balance      Decimal       @default(0) @db.Decimal(10, 2)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model Order {
  id           String      @id @default(uuid())
  userId       String
  productUrl   String
  productName  String
  productImage String?
  priceJpy     Decimal     @db.Decimal(10, 2)
  priceBrl     Decimal     @db.Decimal(10, 2)
  serviceFee   Decimal     @db.Decimal(10, 2)
  fixedFee     Decimal     @db.Decimal(10, 2)
  totalBrl     Decimal     @db.Decimal(10, 2)
  quantity     Int         @default(1)
  variation    String?
  notes        String?
  status       OrderStatus @default(AWAITING_PURCHASE)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("orders")
}

enum OrderStatus {
  AWAITING_PURCHASE
  PURCHASED
  IN_TRANSIT_TO_WAREHOUSE
  IN_WAREHOUSE
  CANCELLED
}

model Transaction {
  id          String          @id @default(uuid())
  walletId    String
  type        TransactionType
  amount      Decimal         @db.Decimal(10, 2)
  description String
  referenceId String?
  createdAt   DateTime        @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

enum TransactionType {
  CREDIT
  ORDER_PAYMENT
  SHIPPING_PAYMENT
  EXTRA_SERVICE
  STORAGE_FEE
  MANUAL_CREDIT
  MANUAL_DEBIT
  REFUND
}

model ExchangeRate {
  id       String   @id @default(uuid())
  date     DateTime @unique @db.Date
  jpyToBrl Decimal  @db.Decimal(10, 4)
  fetchedAt DateTime @default(now())

  @@map("exchange_rates")
}

